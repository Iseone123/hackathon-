# Yandex AI Studio
YC_API_KEY=your_api_key_here
YC_FOLDER_ID=your_folder_id_here

# Services (docker-compose defaults)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hypothesis_neo4j
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hypothesis-data

# API
API_HOST=0.0.0.0
API_PORT=8000
DATA_DIR=/app/data
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Judge objective (JQI) — целевая метрика, которую максимизируем
JUDGE_QUALITY_TARGET=75
JUDGE_OBJECTIVE_APPROVAL_WEIGHT=0.55
JUDGE_OBJECTIVE_SCORE_WEIGHT=0.45
# Строгий режим судьи
JUDGE_MIN_APPROVE_SCORE=6.5
JUDGE_SNIPPET_OVERLAP_MIN=0.30
JUDGE_MIN_LLM_TESTABILITY=6.0
JUDGE_MIN_LLM_EVIDENCE=6.0
JUDGE_MIN_LLM_KPI_LINK=5.5
JUDGE_MIN_LLM_RELEVANCE=6.0
JUDGE_ISSUE_PENALTY=0.55

# Rate limit YandexGPT — пауза между запросами (сек), снижает 429
LLM_REQUEST_DELAY_SEC=3.0
# Параллельные запросы эмбеддингов (Yandex API — по одному тексту на запрос)
EMBED_PARALLEL_WORKERS=4
LLM_MAX_RETRIES=8
GENERATION_SAMPLES=1

# Модели Yandex Foundation Models (без суффикса /latest)
# YandexGPT Pro 5 — генерация гипотез
YANDEXGPT_MODEL=yandexgpt
# YandexGPT Lite 5 — судья и NER
YANDEXGPT_LITE_MODEL=yandexgpt-lite
EMBED_DOC_MODEL=text-search-doc
EMBED_QUERY_MODEL=text-search-query
