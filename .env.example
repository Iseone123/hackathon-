# Yandex AI Studio
YC_API_KEY=
YC_FOLDER_ID=

# Модели (можно заменить на yandexgpt-lite/latest для дешёвых вызовов)
YC_GPT_MODEL=yandexgpt/latest
YC_GPT_MODEL_LITE=yandexgpt-lite/latest

# Пути
DATA_DIR=./backend/data/source   # исходные материалы хакатона (учебники, примеры)
INDEX_DIR=./backend/data/index   # кэш индекса базы знаний
STORE_DIR=./backend/data/store   # гипотезы, фидбэк

# Генерация
N_CONSISTENCY_SAMPLES=2          # сэмплов self-consistency (1 = быстро, 3 = качественно)
API_URL=http://localhost:8000    # для Streamlit UI
