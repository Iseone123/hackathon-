# API-ключ сервисного аккаунта Yandex Cloud (роль ai.languageModels.user или ai.editor)
YANDEX_API_KEY=your_api_key_here

# ID каталога в Yandex Cloud
YANDEX_FOLDER_ID=your_folder_id_here

# Модели (опционально, значения по умолчанию подходят для большинства кейсов)
# YANDEX_CHAT_MODEL=yandexgpt/latest
# YANDEX_EMBED_DOC_MODEL=text-search-doc/latest
# YANDEX_EMBED_QUERY_MODEL=text-search-query/latest
